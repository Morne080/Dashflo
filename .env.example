APP_NAME=Dashflo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dashflo
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Use "sync" locally if you are not running `php artisan queue:work`. Webhook/API ingest still parses payloads
# synchronously so leads appear without a worker.
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Lead file import — set PHP post_max_size / upload_max_filesize >= max upload (KB * 1024 bytes)
# LEAD_IMPORT_MAX_UPLOAD_KB=204800
# LEAD_IMPORT_MAX_ROWS=250000
# LEAD_IMPORT_INSERT_CHUNK_SIZE=1000
# LEAD_IMPORT_ASYNC_VERIFICATION_AFTER_FACTS=2000
# LEAD_IMPORT_MAX_EXECUTION_TIME=0
# Chunked upload for large files (each POST stays under PHP post_max_size)
# LEAD_IMPORT_CHUNKED_THRESHOLD_KB=1024
# LEAD_IMPORT_CHUNK_UPLOAD_KB=2048
# LEAD_IMPORT_CHUNK_SESSION_TTL=86400

# Optional lead verification (per integration source or global fallback)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TRUSTEDFORM_API_KEY=
# ActiveProspect retain endpoint for your account (see ActiveProspect docs)
TRUSTEDFORM_RETAIN_URL=
